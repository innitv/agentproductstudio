{
  "name": "product-agent-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "yarn@1.22.22",
  "description": "Manager-style product landing workflow pack for Codex and OpenAI Agents SDK.",
  "scripts": {
    "agents:inspect": "tsx runtime/typescript/agents.sdk.ts",
    "dev": "vite --config apps/frontend/vite.config.ts --host 127.0.0.1",
    "build": "tsc --noEmit && vite build --config apps/frontend/vite.config.ts",
    "preview": "vite preview --config apps/frontend/vite.config.ts --host 127.0.0.1",
    "qa:playwright": "yarn build && node tooling/scripts/run-and-log.mjs playwright \"playwright test\"",
    "qa:firecrawl": "yarn build && node tooling/scripts/run-and-log.mjs playwright-firecrawl \"playwright test tests/playwright/firecrawl.spec.ts\"",
    "qa:playwright:install": "playwright install chromium",
    "docs:audit": "node tooling/scripts/run-and-log.mjs docs-audit \"node tooling/scripts/audit-docs.mjs\"",
    "qa:quick": "yarn typecheck && yarn validate:config && yarn docs:audit",
    "qa:all": "yarn qa:quick && yarn qa:playwright",
    "project:audit": "yarn qa:all",
    "notion:check": "node tooling/scripts/check-notion-token.mjs",
    "notion:mcp": "notion-mcp-server --transport stdio",
    "notion:publish-research-hub": "node tooling/scripts/publish-notion-research-hub.mjs",
    "notion:publish-stories": "node tooling/scripts/publish-notion-stories.mjs",
    "validate:config": "node tooling/scripts/run-and-log.mjs validate-config \"node tooling/scripts/validate-config.mjs && tsx runtime/typescript/validate-config-semantics.ts\"",
    "workflow:validate": "tsx runtime/typescript/validate-workflow-run.ts",
    "workflow:sync": "tsx runtime/typescript/sync-run-state.ts",
    "workflow:run-local": "tsx runtime/typescript/run-local-workflow.ts",
    "workflow:start": "tsx runtime/typescript/run-workflow-engine.ts start",
    "workflow:resume": "tsx runtime/typescript/run-workflow-engine.ts resume",
    "workflow:status": "tsx runtime/typescript/run-workflow-engine.ts status",
    "workflow:list": "tsx runtime/typescript/run-workflow-engine.ts list",
    "workflow:inspect": "tsx runtime/typescript/run-workflow-engine.ts inspect",
    "workflow:outputs": "tsx runtime/typescript/run-workflow-engine.ts outputs",
    "workflow:skills": "tsx runtime/typescript/run-workflow-engine.ts skills",
    "workflow:cleanup-temp": "tsx runtime/typescript/run-workflow-engine.ts cleanup-temp",
    "workflow:archive": "tsx runtime/typescript/run-workflow-engine.ts archive",
    "workflow:run-stage": "tsx runtime/typescript/run-workflow-engine.ts run-stage",
    "workflow:approve": "tsx runtime/typescript/run-workflow-engine.ts approve",
    "workflow:deny": "tsx runtime/typescript/run-workflow-engine.ts deny",
    "workflow:approval-request": "tsx runtime/typescript/run-workflow-engine.ts approval-request",
    "workflow:approvals": "tsx runtime/typescript/run-workflow-engine.ts approvals",
    "workflow:agentic-stages": "tsx runtime/typescript/run-workflow-engine.ts agentic-stages",
    "workflow:agentic-readiness": "tsx runtime/typescript/run-workflow-engine.ts agentic-readiness",
    "workflow:agentic-approval-commands": "tsx runtime/typescript/run-workflow-engine.ts agentic-approval-commands",
    "workflow:agentic-preflight": "tsx runtime/typescript/run-workflow-engine.ts agentic-preflight",
    "workflow:doctor": "tsx runtime/typescript/doctor.ts",
    "workflow:test-validator": "tsx runtime/typescript/test-workflow-validator.ts",
    "workflow:test-agentic": "yarn workflow:test-agentic-rollout && yarn workflow:test-approval-gate && yarn workflow:test-agent-metadata && yarn workflow:test-skill-metadata && yarn workflow:test-skill-usage && yarn workflow:test-output-metadata && yarn workflow:test-output-lifecycle && yarn workflow:test-agentic-executor && yarn workflow:test-agentic-readiness && yarn workflow:test-agentic-engine",
    "workflow:test-agent-metadata": "tsx runtime/typescript/test-agent-metadata.ts",
    "workflow:test-skill-metadata": "tsx runtime/typescript/test-skill-metadata.ts",
    "workflow:test-skill-usage": "tsx runtime/typescript/test-skill-usage.ts",
    "workflow:test-output-metadata": "tsx runtime/typescript/test-output-metadata.ts",
    "workflow:test-output-lifecycle": "tsx runtime/typescript/test-output-lifecycle.ts",
    "workflow:test-multi-source-research": "tsx runtime/typescript/test-multi-source-research.ts",
    "workflow:test-agentic-rollout": "tsx runtime/typescript/test-agentic-rollout.ts",
    "workflow:test-approval-gate": "tsx runtime/typescript/test-approval-gate.ts",
    "workflow:test-agentic-executor": "tsx runtime/typescript/test-agentic-executor.ts",
    "workflow:test-agentic-readiness": "yarn tsx runtime/typescript/test-agentic-readiness.ts",
    "workflow:test-agentic-engine": "tsx runtime/typescript/test-agentic-engine.ts",
    "reference:scan": "tsx runtime/typescript/reference-scan.ts",
    "reference:diff": "tsx runtime/typescript/visual-diff.ts",
    "reference:section-diff": "tsx runtime/typescript/visual-section-diff.ts",
    "reference:review": "tsx runtime/typescript/visual-reference-review.ts",
    "research:run": "tsx runtime/typescript/research-stage-runner.ts",
    "research:lint": "node tooling/scripts/lint-research-content.mjs",
    "typecheck": "node tooling/scripts/run-and-log.mjs typecheck \"tsc --noEmit\"",
    "landing:run": "tsx runtime/typescript/run-landing-workflow.ts",
    "outputs:cleanup": "node tooling/scripts/cleanup-outputs.mjs"
  },
  "dependencies": {
    "@openai/agents": "0.11.4",
    "@radix-ui/react-slot": "1.2.4",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "framer-motion": "12.40.0",
    "lucide-react": "1.16.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@mendable/firecrawl-js": "4.25.0",
    "@notionhq/notion-mcp-server": "2.2.1",
    "@playwright/test": "1.60.0",
    "@tailwindcss/vite": "4.3.0",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "js-yaml": "4.1.1",
    "tailwindcss": "4.3.0",
    "tsx": "4.22.3",
    "typescript": "6.0.3",
    "vite": "8.0.14"
  },
  "engines": {
    "node": ">=22"
  }
}
