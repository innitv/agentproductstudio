{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./apps/frontend/src/*"],
      "@portfolio/*": ["./apps/portfolio/src/*"],
      "@siteportfolio/*": ["./siteportfolio/src/*"]
    },
    "types": ["node", "vite/client"]
  },
  "include": [
    "runtime/typescript/**/*.ts",
    "apps/frontend/src/**/*.ts",
    "apps/frontend/src/**/*.tsx",
    "apps/portfolio/src/**/*.ts",
    "apps/portfolio/src/**/*.tsx",
    "siteportfolio/src/**/*.ts",
    "siteportfolio/src/**/*.tsx",
    "apps/frontend/vite.config.ts",
    "apps/portfolio/vite.config.ts",
    "playwright.config.ts",
    "tests/**/*.ts"
  ],
  "exclude": ["node_modules", "outputs"]
}
