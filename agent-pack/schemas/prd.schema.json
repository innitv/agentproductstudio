{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://product-agent-studio.local/schemas/prd.schema.json",
  "title": "PRD",
  "type": "object",
  "required": ["status", "inputs_used", "problem", "goals", "non_goals", "requirements", "moscow", "acceptance_criteria", "analytics"],
  "properties": {
    "status": { "enum": ["draft", "partial", "blocked", "ready"] },
    "inputs_used": { "type": "array", "items": { "type": "string" } },
    "problem": { "type": "string", "minLength": 1 },
    "goals": { "type": "array", "items": { "type": "string" } },
    "non_goals": { "type": "array", "items": { "type": "string" } },
    "requirements": { "type": "array", "items": { "$ref": "#/$defs/requirement" } },
    "decision_input_audit": { "type": "array", "items": { "$ref": "#/$defs/decision_input" } },
    "evidence_to_requirement_map": { "type": "array", "items": { "$ref": "#/$defs/evidence_requirement_map" } },
    "user_stories": { "type": "array", "items": { "$ref": "#/$defs/user_story" } },
    "traceability_matrix": { "type": "array", "items": { "$ref": "#/$defs/traceability_item" } },
    "moscow": {
      "type": "object",
      "required": ["must", "should", "could", "wont"],
      "properties": {
        "must": { "type": "array", "items": { "type": "string" } },
        "should": { "type": "array", "items": { "type": "string" } },
        "could": { "type": "array", "items": { "type": "string" } },
        "wont": { "type": "array", "items": { "type": "string" } }
      }
    },
    "acceptance_criteria": { "type": "array", "items": { "type": "string" } },
    "analytics": { "type": "array", "items": { "$ref": "#/$defs/analytics_event" } },
    "prd_to_design_handoff": { "$ref": "#/$defs/prd_to_design_handoff" }
  },
  "$defs": {
    "decision_input": {
      "type": "object",
      "required": ["decision", "inputs_used", "evidence_status", "decision_state"],
      "properties": {
        "decision": { "type": "string" },
        "inputs_used": { "type": "array", "items": { "type": "string" } },
        "evidence_status": { "type": "string" },
        "decision_state": { "enum": ["ready", "partial", "blocked", "needs_validation"] },
        "notes": { "type": "string" }
      }
    },
    "evidence_requirement_map": {
      "type": "object",
      "required": ["evidence", "product_implication", "requirement_id", "priority", "validation_state"],
      "properties": {
        "evidence": { "type": "string" },
        "product_implication": { "type": "string" },
        "requirement_id": { "type": "string" },
        "priority": { "enum": ["must", "should", "could", "wont"] },
        "validation_state": { "type": "string" }
      }
    },
    "user_story": {
      "type": "object",
      "required": ["id", "role", "action", "value"],
      "properties": {
        "id": { "type": "string" },
        "role": { "type": "string" },
        "action": { "type": "string" },
        "value": { "type": "string" },
        "journey_step": { "type": "string" },
        "requirement_ids": { "type": "array", "items": { "type": "string" } }
      }
    },
    "traceability_item": {
      "type": "object",
      "required": ["requirement_id", "acceptance_criteria", "test_signal"],
      "properties": {
        "requirement_id": { "type": "string" },
        "user_story_id": { "type": "string" },
        "evidence_or_jtbd": { "type": "string" },
        "acceptance_criteria": { "type": "array", "items": { "type": "string" } },
        "analytics_or_test_signal": { "type": "string" },
        "test_signal": { "type": "string" }
      }
    },
    "requirement": {
      "type": "object",
      "required": ["id", "description", "priority"],
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "priority": { "enum": ["must", "should", "could", "wont"] },
        "evidence_status": { "type": "string" },
        "user_story_id": { "type": "string" },
        "business_value": { "type": "string" },
        "acceptance_criteria_ids": { "type": "array", "items": { "type": "string" } }
      }
    },
    "analytics_event": {
      "type": "object",
      "required": ["event", "trigger", "pii_risk"],
      "properties": {
        "event": { "type": "string" },
        "trigger": { "type": "string" },
        "properties": { "type": "array", "items": { "type": "string" } },
        "pii_risk": { "enum": ["none", "low", "medium", "high"] }
      }
    },
    "prd_to_design_handoff": {
      "type": "object",
      "properties": {
        "primary_screen": { "type": "string" },
        "primary_action": { "type": "string" },
        "critical_user_path": { "type": "array", "items": { "type": "string" } },
        "trust_and_proof": { "type": "array", "items": { "type": "string" } },
        "required_states": { "type": "array", "items": { "type": "string" } },
        "content_constraints": { "type": "array", "items": { "type": "string" } },
        "design_open_questions": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
