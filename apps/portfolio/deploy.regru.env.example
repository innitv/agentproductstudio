# Скопируй этот файл в корень репозитория как .env.portfolio-deploy
# и заполни реальными FTP/FTPS-данными из панели Reg.ru.

PORTFOLIO_FTP_PROTOCOL=ftp
PORTFOLIO_FTP_HOST=ftp.example.ru
PORTFOLIO_FTP_PORT=21
PORTFOLIO_FTP_USER=login
PORTFOLIO_FTP_PASSWORD=password

# Папка сайта на хостинге Reg.ru.
# Частые варианты: /public_html, /www/example.ru, /www/ivan-ignatov.online
PORTFOLIO_FTP_REMOTE_DIR=/public_html
