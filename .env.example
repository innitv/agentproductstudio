# Optional. Only needed for standalone local OpenAI Agents SDK runtime.
OPENAI_API_KEY=

# Optional research provider.
TAVILY_API_KEY=

# Optional comma-separated local runtime order. Available executable providers:
# tavily,deepseek
RESEARCH_PROVIDER_ORDER=tavily,deepseek

# Optional publication / repository / design providers.
NOTION_TOKEN=
GITHUB_PERSONAL_ACCESS_TOKEN=
GITHUB_READ_ONLY=1

# Required for default deep research verification together with Tavily.
DEEPSEEK_API_KEY=
DEEPSEEK_RESEARCH_MODEL=deepseek-v4-flash

# Optional Firecrawl web scrape/browser-interact provider for Playwright-backed checks.
FIRECRAWL_API_KEY=
FIRECRAWL_API_URL=
FIRECRAWL_TEST_URL=https://example.com
FIRECRAWL_TIMEOUT_MS=60000
