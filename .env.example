# Optional. Only needed for standalone local OpenAI Agents SDK runtime.
OPENAI_API_KEY=

# Optional research provider.
TAVILY_API_KEY=

# Optional comma-separated local runtime order.
# Default source-backed research uses tavily only.
# To explicitly opt in advisory checks, use for example: tavily,gemini
RESEARCH_PROVIDER_ORDER=tavily

# Optional publication / repository / design providers.
NOTION_TOKEN=
FIGMA_API_TOKEN=
GITHUB_PERSONAL_ACCESS_TOKEN=
GITHUB_READ_ONLY=1

# Optional opt-in advisory check for contradiction review; not part of default deep research.
DEEPSEEK_API_KEY=
DEEPSEEK_RESEARCH_MODEL=deepseek-v4-flash

# Optional opt-in advisory check for contradiction review; not part of default deep research.
GEMINI_API_KEY=
GEMINI_RESEARCH_MODEL=gemini-2.5-flash

# Optional Firecrawl web scrape/browser-interact provider for Playwright-backed checks.
FIRECRAWL_API_KEY=
FIRECRAWL_API_URL=
FIRECRAWL_TEST_URL=https://example.com
FIRECRAWL_TIMEOUT_MS=60000
