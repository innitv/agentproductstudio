{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Figma component contract registry",
  "type": "object",
  "required": ["fileKey", "codeConnectStatus", "components"],
  "properties": {
    "designSystemSlug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "fileKey": { "type": "string", "minLength": 1 },
    "fileName": { "type": "string" },
    "codeConnectStatus": {
      "enum": ["connected", "unavailable_plan", "not_configured", "skipped_with_reason"]
    },
    "codeConnectCheckedAt": { "type": "string", "format": "date" },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "nodeId", "codeSource", "codeExport", "expectedVariants"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "nodeId": { "type": "string", "pattern": "^[0-9]+:[0-9]+$" },
          "source": {
            "type": "object",
            "properties": {
              "designSystemSlug": { "type": "string" },
              "figmaUrl": { "type": "string" },
              "category": { "type": "string" }
            },
            "additionalProperties": false
          },
          "codeSource": { "type": "string", "minLength": 1 },
          "codeExport": { "type": "string", "minLength": 1 },
          "expectedVariants": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            }
          },
          "semanticVariables": { "type": "array", "items": { "type": "string" } },
          "slots": { "type": "array", "items": { "type": "string" } },
          "resizeContract": { "type": "string" },
          "requiredStates": { "type": "array", "items": { "type": "string" } },
          "storyTestLocator": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
